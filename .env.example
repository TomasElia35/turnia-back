# ── Base de datos (PostgreSQL — local o Supabase) ─────────────────────────
# DESARROLLO (Postgres local):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/galart
DB_SSL=false
# PRODUCCIÓN (Supabase → Project Settings → Database → Connection string → URI, modo pooler):
# DATABASE_URL=postgres://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres
# DB_SSL=true

# ── Auth ──────────────────────────────────────────────────────────────────
# Secreto para firmar los JWT propios de la app (generá uno largo y aleatorio)
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# ── Google OAuth (preparado, opcional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (recuperación de contraseña — preparado, opcional) ──────────────
# Ej: Resend, SendGrid, SMTP. Si está vacío, el envío se simula (modo MVP).
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM=no-reply@galart.app
# Base del frontend para armar el link de reseteo
FRONTEND_URL=http://localhost:5173

# ── Supabase Storage (subida de imágenes al bucket público) ───────────────
# Supabase → Project Settings → API:
#   SUPABASE_URL          = "Project URL"  (ej: https://xxxx.supabase.co)
#   SUPABASE_SERVICE_ROLE_KEY = clave "service_role" (secreta, NUNCA en el frontend)
# El bucket debe existir y ser público (por defecto: "imagenes").
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=imagenes

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:5173
