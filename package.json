{
  "name": "turnia-backend",
  "version": "1.0.0",
  "description": "Backend de Turnia — Express + Supabase (Postgres), desplegable en Vercel como función serverless.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:setup": "node scripts/db-setup.js",
    "seed": "node scripts/seed.js",
    "check": "node --check src/app.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "serverless-http": "^3.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {}
}
